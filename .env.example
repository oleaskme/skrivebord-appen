# Supabase
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# Google OAuth (server-side only — sett i Vercel dashboard, ikke her)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://<ditt-vercel-domene>/api/auth/google/callback

# Anthropic (server-side only)
ANTHROPIC_API_KEY=

# Krypteringsnøkkel for Google refresh-tokens lagret i Supabase
TOKEN_ENCRYPTION_KEY=
